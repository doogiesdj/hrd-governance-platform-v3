# HRD Governance Platform — Environment Variables
# 이 파일을 복사하여 .env 로 저장하고 실제 값을 입력하세요.
# .env 파일은 절대 git에 커밋하지 마세요.

# ──────────────────────────────────────────
# NLQ (자연어 질의) API 설정
# ──────────────────────────────────────────

# Claude API Key (Anthropic)
# 발급: https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here

# Google Gemini API Key
# 발급: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 기본 사용 공급자 (claude | gemini)
NLQ_PROVIDER=claude

# ──────────────────────────────────────────
# Phase 2+ 백엔드 설정 (현재 미사용)
# ──────────────────────────────────────────

# Apache Jena Fuseki SPARQL 엔드포인트
# FUSEKI_ENDPOINT=http://localhost:3030/hrd/sparql

# FastAPI 백엔드 URL
# BACKEND_URL=http://localhost:8000
